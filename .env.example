# Browser-safe values. No other variable may use NEXT_PUBLIC_.
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_PRIVY_APP_ID=

# Web runtime identity for the one-app Vercel MVP.
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_VERIFICATION_KEY=
RESEND_API_KEY=
EMAIL_FROM=
OPERATOR_EMAILS=

# Project-attached private Vercel Blob state and scheduled wakeup.
BLOB_READ_WRITE_TOKEN=
# Vercel Cron sends this as Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=

# Privy worker authority. Keep every value server-only.
PRIVY_AUTHORIZATION_PRIVATE_KEY=
PRIVY_KEY_QUORUM_ID=
PRIVY_POLYMARKET_POLICY_ID=
PRIVY_DFLOW_POLICY_ID=

# Legacy/deferred SQL foundation. Leave blank for the Vercel hackathon MVP.
SUPABASE_WEB_DATABASE_URL=
SUPABASE_MARKET_DATABASE_URL=
SUPABASE_EXECUTION_DATABASE_URL=
SUPABASE_MIGRATION_DATABASE_URL=

# AES-256-GCM keyring. See docs/runbooks/envelope-key-rotation.md.
TXBET_ENVELOPE_ACTIVE_KEY_ID=
TXBET_ENVELOPE_KEYRING_JSON=

# TxLINE World Cup feed. Keep real values in .env only.
TXLINE_BASE_URL=https://txline.txodds.com
TXLINE_API_TOKEN=
TXLINE_WORLD_CUP_COMPETITION_IDS=
TXLINE_FIXTURE_ID=

# Versioned collateral evidence shared by market and execution workers.
ASSET_VALUE_POLICIES_JSON=

# Polymarket and Polygon.
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_MARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLYMARKET_USER_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/user
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
# Versioned reviewed pair artifact. Leave blank to disable the public shadow scan.
POLYMARKET_WORLD_CUP_SHADOW_REVIEW_JSON=
POLYMARKET_RELAYER_URL=https://relayer-v2.polymarket.com/
POLYMARKET_CHAIN_ID=137
POLYMARKET_COLLATERAL_ADDRESS=0xC011a7E12a19f7B1f670d46F03B03f3342E82DFB
POLYMARKET_CTF_ADDRESS=0x4D97DCd97eC945f40cF65F87097ACe5EA0476045
POLYMARKET_EXCHANGE_ALLOWLIST=["0xE111180000d2663C0091e4f400237545B87B996B","0xe2222d279d744050d28e00520010520000310F59"]
POLYMARKET_RELAYER_API_KEY=
POLYMARKET_RELAYER_API_KEY_ADDRESS=
POLYGON_RPC_URL=

# DFlow and Solana.
DFLOW_API_BASE_URL=https://quote-api.dflow.net
DFLOW_WS_URL=wss://quote-api.dflow.net
DFLOW_API_KEY=
# Server-reviewed 2026 World Cup market/mint bindings and DFlow program IDs.
DFLOW_WORLD_CUP_BINDINGS_JSON=
DFLOW_PROGRAM_ALLOWLIST_JSON=
# Manual exact-input canary controls. Keep explicit and conservative.
DFLOW_LIVE_SLIPPAGE_BPS=50
DFLOW_LIVE_PREDICTION_MARKET_SLIPPAGE_BPS=100
DFLOW_MAX_PRIORITY_FEE_LAMPORTS=
DFLOW_MAX_INIT_COST_LAMPORTS=
DFLOW_BASE_FEE_LAMPORTS=5000
SOLANA_RPC_URL=

# Conservative native-token valuation ceilings and evidence expiry.
POLYGON_NATIVE_USD_UPPER_BOUND_MICROS=
SOLANA_NATIVE_USD_UPPER_BOUND_MICROS=
BSC_NATIVE_USD_UPPER_BOUND_MICROS=
BASE_NATIVE_USD_UPPER_BOUND_MICROS=
SX_NETWORK_NATIVE_USD_UPPER_BOUND_MICROS=
HYDROMANCER_NATIVE_USD_UPPER_BOUND_MICROS=
POLYGON_NETWORK_COST_POLICY_VALID_UNTIL=
SOLANA_NETWORK_COST_POLICY_VALID_UNTIL=
BSC_NETWORK_COST_POLICY_VALID_UNTIL=
BASE_NETWORK_COST_POLICY_VALID_UNTIL=
SX_NETWORK_COST_POLICY_VALID_UNTIL=
HYDROMANCER_NETWORK_COST_POLICY_VALID_UNTIL=

# Live entry remains disabled until the operator explicitly changes this value.
EXECUTION_MODE=disabled
RECOVERY_ACTION_MODE=frozen
CANARY_MAX_TOTAL_MICROS=10000000
