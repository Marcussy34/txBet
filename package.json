{
  "name": "txbet",
  "version": "0.1.0",
  "description": "World Cup hackathon prototype for TxLINE-format, event-triggered exact-complement strategies.",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.17.1",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10 <11"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:workers": "tsup",
    "db:start": "supabase start",
    "db:reset": "supabase db reset",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "vitest run",
    "test:db": "supabase test db",
    "test:e2e": "playwright test",
    "test:workers": "vitest run tests/workers",
    "test:watch": "vitest",
    "agent:demo": "tsx scripts/replay.ts",
    "dflow:smoke": "tsx scripts/smoke-dflow.ts",
    "txline:smoke": "tsx scripts/smoke-txline.ts",
    "verify": "pnpm audit:production && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "audit:production": "pnpm audit --prod --audit-level high",
    "worker:market-data": "node dist/workers/market-data.js",
    "worker:execution": "node dist/workers/execution.js"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@gsap/react": "^2.1.2",
    "@noble/ed25519": "3.1.0",
    "@polymarket/client": "0.1.0-beta.16",
    "@privy-io/node": "^0.26.0",
    "@privy-io/react-auth": "^3.35.1",
    "@solana/web3.js": "1.98.4",
    "bs58": "6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "eventsource": "^4.1.0",
    "gsap": "^3.15.0",
    "lucide-react": "^1.24.0",
    "motion": "^12.42.2",
    "next": "16.2.10",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.17.2",
    "server-only": "^0.0.1",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "viem": "2.55.2",
    "ws": "8.21.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "^26.1.0",
    "supabase": "^2.109.1",
    "tailwindcss": "^4",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
